{
  "name": "goldspire-veil",
  "version": "1.0.0",
  "private": true,
  "description": "Veil by Goldspire — browser extension + hosted unlock page",
  "type": "module",
  "scripts": {
    "env:apply": "node scripts/apply-env.mjs",
    "deploy:portal": "npm run env:apply && npx wrangler pages deploy api/public --project-name=veil --branch=main",
    "deploy:worker": "npx wrangler deploy --cwd infra/veil-portal-worker",
    "package": "npm run env:apply && node extension/scripts/package.mjs && node scripts/deploy-pages.mjs",
    "package:store": "npm run package && node scripts/package-store.mjs",
    "build": "npm run package",
    "start": "node api/src/server.mjs",
    "db:migrate": "node api/scripts/migrate.mjs",
    "db:seed": "node api/scripts/seed.mjs",
    "setup:cloud": "npm run db:migrate && npm run db:seed",
    "api:dev": "node api/src/server.mjs",
    "dev": "npm run env:apply && npm run api:dev",
    "stripe:listen": "stripe listen --forward-to localhost:3015/v1/webhooks/stripe",
    "test": "node --test tests/detection/*.test.mjs tests/scenarios/*.test.mjs tests/share-recipients.test.mjs tests/feedback.test.mjs tests/billing.test.mjs tests/support.test.mjs tests/learning.test.mjs tests/personal-email.test.mjs",
    "learning:analyze": "node api/scripts/run-learning-analysis.mjs",
    "learning:train": "node api/scripts/run-learning-train.mjs",
    "learning:export": "python analysis/export_signals.py --days 30 --out analysis/exports/decisions.jsonl",
    "test:daily-use": "node --test tests/scenarios/daily-use.test.mjs tests/scenarios/snooze.test.mjs tests/scenarios/copilot-settings-refresh.test.mjs",
    "test:detection": "node --test tests/detection/*.test.mjs",
    "test:scenarios": "node --test tests/scenarios/*.test.mjs",
    "e2e": "node scripts/e2e-smoke.mjs",
    "test:practice-ext": "node scripts/practice-extension-smoke.mjs",
    "test:extension-smoke": "node scripts/veil-extension-smoke.mjs",
    "test:store-ready": "node scripts/veil-store-smoke.mjs",
    "product:walk": "node scripts/product-walk.mjs",
    "product:e2e": "node scripts/product-e2e-walk.mjs",
    "release:gate": "npm test && npm run product:e2e",
    "capture:store": "node scripts/capture-store-screenshots.mjs",
    "docs:screenshots": "node scripts/sync-doc-screenshots.mjs",
    "capture:docs": "npm run capture:store && npm run docs:screenshots",
    "stripe:setup": "node scripts/setup-stripe-veil.mjs"
  },
  "devDependencies": {
    "playwright": "^1.52.0"
  },
  "dependencies": {
    "pg": "^8.16.0",
    "stripe": "^22.2.1"
  }
}
